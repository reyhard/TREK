PORT=3001 # Port to run the server on
# HOST=0.0.0.0 # Bind address for the HTTP server. Only set this when running TREK from sources or via the Proxmox community script — never in Docker (the container handles binding).
NODE_ENV=development # development = development mode; production = production mode
# ENCRYPTION_KEY=<random-256-bit-hex>  # Separate key for encrypting stored secrets (API keys, MFA, SMTP, OIDC, etc.)
# Auto-generated and persisted to ./data/.encryption_key if not set.
# Upgrade from a version that used JWT_SECRET for encryption: set to your old JWT_SECRET value so
# existing encrypted data remains readable, then re-save credentials via the admin panel.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TZ=UTC # Timezone for logs, reminders and scheduled tasks (e.g. Europe/Berlin)
# DEFAULT_LANGUAGE=en # Default language on the login page for users with no saved preference (default: en)
# SESSION_DURATION=30d # How long users stay logged in — sets the trek_session JWT exp + cookie maxAge. Accepts 1h, 12h, 7d, 30d, 90d. Default: 24h
# SESSION_DURATION_REMEMBER=30d # Session length when "Remember me" is ticked at login — longer-lived JWT + persistent cookie that survives browser restarts. Same format as SESSION_DURATION. Default: 30d
# Supported values: de, en, es, fr, hu, nl, br, cs, pl, ru, zh, zh-TW, it, ar
# Note: browser/OS language is detected automatically first; this is the fallback when no match is found.
LOG_LEVEL=info # info = concise user actions; debug = verbose admin-level details
# TREK_WIKI_DIR=../wiki # Where the in-app Help pages (/help) read their content from. Leave unset: the repo's wiki/ directory is found automatically, so Help always matches the version you are running. Only set this to point at your own docs. If the path does not exist, Help falls back to fetching the public GitHub wiki (needs outbound network).

ALLOWED_ORIGINS=https://trek.example.com # Comma-separated origins for CORS and email links
FORCE_HTTPS=false # Optional. When true: HTTPS redirect + HSTS + CSP upgrade-insecure-requests + secure cookies. Only behind a TLS proxy.
# HSTS_INCLUDE_SUBDOMAINS=false # When true: adds includeSubDomains to the HSTS header. Only effective when HSTS is active (FORCE_HTTPS=true or NODE_ENV=production). Leave false if you run other services on sibling subdomains over plain HTTP.
COOKIE_SECURE=true # Auto-derived (true when NODE_ENV=production or FORCE_HTTPS=true). Set false to force cookies over plain HTTP.
TRUST_PROXY=1 # Trusted proxy hops (parseInt or 1). Active in production by default; off in dev unless set. Needed for FORCE_HTTPS.
ALLOW_INTERNAL_NETWORK=false # Allow outbound requests to private/RFC1918 IPs (e.g. Immich hosted on your LAN). Loopback and link-local addresses are always blocked.

APP_URL=https://trek.example.com # Base URL of this instance — required when OIDC is enabled; must match the redirect URI registered with your IdP

OIDC_ISSUER=https://auth.example.com # OpenID Connect provider URL
OIDC_CLIENT_ID=trek # OpenID Connect client ID
OIDC_CLIENT_SECRET=supersecret # OpenID Connect client secret
OIDC_DISPLAY_NAME=SSO # Label shown on the SSO login button
OIDC_ONLY=true # Disable local password auth entirely (SSO only). Equivalent to setting password_login=false and password_registration=false in Admin > Settings.
OIDC_ADMIN_CLAIM=groups # OIDC claim used to identify admin users
OIDC_ADMIN_VALUE=app-trek-admins # Value of the OIDC claim that grants admin role
OIDC_DISCOVERY_URL= # Override the auto-constructed OIDC discovery endpoint. Useful for providers (e.g. Authentik) that expose it at a non-standard path. Example: https://auth.example.com/application/o/trek/.well-known/openid-configuration
OIDC_SCOPE=openid email profile # Fully overrides the default. Add extra scopes as needed (e.g. add groups if using OIDC_ADMIN_CLAIM)

DEMO_MODE=false # Demo mode - resets data hourly
# DEMO_ADMIN_USER=admin # Username of the seeded demo admin account (default: admin). Only used when DEMO_MODE=true.
# DEMO_ADMIN_EMAIL=admin@trek.app # Email of the seeded demo admin account (default: admin@trek.app). Only used when DEMO_MODE=true.
# DEMO_ADMIN_PASS=admin12345 # Initial password for the seeded demo admin (default: admin12345). Only used when DEMO_MODE=true.

# BACKUP_UPLOAD_LIMIT_MB=500 # Max size (MB) of a backup archive you can upload when restoring. Raise it if your backup exceeds 500 MB. If you sit behind a reverse proxy, raise its upload limit too (e.g. nginx client_max_body_size).

# BACKUP_MAX_DECOMPRESSED_MB=5120 # Upper bound on total decompressed size of a restore archive (default: 5120 MB / 5 GB). The upload limit caps compressed bytes; this caps unpacked bytes. Raise if your backup (including plugin trees) legitimately exceeds 5 GB when extracted.

# IDEMPOTENCY_TTL_SECONDS=2592000 # TTL (seconds) for X-Idempotency-Key entries in the database (default: 2592000 / 30 days). Must exceed the maximum expected offline window to prevent duplicate replay on reconnect. Raise for multi-week offline use; lower reduces DB cleanup retention.

# MCP_RATE_LIMIT=300 # Max MCP API requests per user per minute (default: 300)
# MCP_MAX_SESSION_PER_USER=20 # Max concurrent MCP sessions per user (default: 20)
# MCP_SESSION_TTL=3600 # MCP session idle timeout in seconds (default: 3600)
# MCP_SSE_KEEPALIVE=25 # SSE keep-alive interval in seconds, 0 = off (default: 25). Keeps reverse proxies from killing idle SSE streams between tool calls.

# TREK_API_DOCS_ENABLED=false # Serve Swagger UI / OpenAPI spec at /api/docs (default: false). Off by default because the generated spec enumerates every route, including the admin surface. Set 'true' to enable.

# TRANSIT_API_URL= # Base URL for a Transitous-compatible public-transit routing API. When set, overrides the default public Transitous endpoint. Point it at your own Transitous instance for locked-down egress.
# KITINERARY_EXTRACTOR_PATH= # Full path to kitinerary-extractor binary. Auto-detected from PATH and /usr/lib/*/libexec/kf6/ when unset.

# OAUTH_HTTP_REDIRECT_HOSTS= # Comma-separated list of LAN hostnames allowed for HTTP OAuth redirect URIs (default: only localhost/127.0.0.1/[::1]).
# TREK_PLUGINS_ENABLED=true # Kill switch for the entire plugin system (default: true). Set to false to disable.
# TREK_PLUGINS_DIR= # Override root directory for installed plugin code. Default: data/plugins.
# TREK_PLUGINS_DATA_DIR= # Override root directory for plugin-writable data. Default: data/plugins-data.
# TREK_PLUGINS_DEV_LINK= # Enable dev-link for loading plugins from local build dirs. Set to 1 (development only). Default: off.
# TREK_PLUGIN_PERMISSIONS=on # OS permission jail for plugin child processes (default: on). Set to 'off' to disable.
# TREK_PLUGIN_ALLOW_PRIVATE_EGRESS= # Permit plugin child processes to reach private/RFC-1918 network targets (e.g. a sibling service on the same Docker network). Set to 'on' to allow; default (unset) blocks LAN/private-network addresses.
# TREK_PLUGIN_REGISTRY_URL= # Override the plugin registry index URL. Default: GitHub TREK-Plugins main dist/index.json.
# TREK_PLUGIN_RPC_BURST=60 # Per-plugin RPC burst allowance (default: 60).
# TREK_PLUGIN_RPC_PER_SEC=20 # Per-plugin sustained RPC calls/sec (default: 20).
# TREK_PLUGIN_RPC_INFLIGHT=16 # Max concurrent in-flight RPC calls per plugin (default: 16).
# TREK_PLUGIN_LOG_BURST=50 # Per-plugin log burst allowance (default: 50).
# TREK_PLUGIN_LOG_PER_SEC=10 # Per-plugin sustained log lines/sec (default: 10).
# TREK_PLUGIN_AI_PER_DAY=200 # Max AI broker calls per plugin per day (default: 200).
# TREK_PLUGIN_NOTIFY_PER_DAY=100 # Max notification sends per plugin per day (default: 100).
# TREK_PLUGIN_AUDIT_MAX_ROWS=20000 # Max audit log rows retained per plugin (default: 20000).
# TREK_PLUGIN_MAX_RSS_MB=300 # Max RSS memory per plugin child in MB (default: 300).

# OVERPASS_URL= # Custom Overpass endpoint(s) for the map POI "explore" search, comma-separated. When set, REPLACES the bundled public mirrors — point it at an internal/self-hosted Overpass instance when the public ones are unreachable from your network. Non-http(s) entries are ignored. If you don't self-host Overpass but the public mirrors throttle you, setting APP_URL also gives outbound requests a unique User-Agent the mirrors rate-limit less.
# OVERPASS_TIMEOUT_MS=12000 # Per-endpoint timeout (ms) for Overpass POI requests; slower endpoints are abandoned so a faster mirror wins. Raise it for a slow self-hosted instance. (default: 12000)

# UNSPLASH_ACCESS_KEY= # Optional Unsplash Access Key for trip-cover and place-image search. Without one, TREK uses Unsplash's unauthenticated endpoint, which some datacenter/VPS IPs get blocked from (#1449). Get a free key at unsplash.com/developers. Overrides any key set per-admin in Admin > Settings. Can also be configured there instead of here.

# TREK_PLACE_PHOTO_DIR= # Override directory for cached Google Places photo thumbnails. Default: uploads/photos/google. Primarily a test seam so tests never touch the real uploads tree; you should not normally need to set this.

# WebAuthn / Passkeys — set these if you use TREK behind a reverse proxy on a custom domain.
# When unset, WEBAUTHN_ORIGINS defaults to APP_URL (or localhost) and WEBAUTHN_RP_ID defaults to the hostname.
# WEBAUTHN_ORIGINS=https://trek.example.com # Comma-separated list of allowed WebAuthn origins
# WEBAUTHN_RP_ID=trek.example.com # WebAuthn relying party ID (usually the domain without scheme/port)

# SMTP — outbound email for notifications. Configured via Admin > Settings by default; these env vars override.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=trek@example.com
# SMTP_PASS=secret
# SMTP_FROM=TREK <trek@example.com>
# SMTP_SKIP_TLS_VERIFY=false # Set true to skip TLS cert validation (e.g. self-signed certs)

# Initial admin account — ONLY applied on the first boot, when the database has no
# users yet. Adding these later has no effect (the server logs a reminder if you do);
# to change an existing password sign in and use Settings, or reset the admin account.
# Both must be set together. If either is omitted, a random password is generated and
# printed to the server log under "First Run: Admin Account Created" — watch for it.
# ADMIN_EMAIL=admin@trek.local
# ADMIN_PASSWORD=change-me-before-first-boot
